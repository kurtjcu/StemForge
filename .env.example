# StemForge environment configuration
# Copy to .env and edit as needed:  cp .env.example .env

# Shared model cache directory.
# Point multiple installs at one folder to avoid duplicate downloads.
# Default (if unset): ~/.cache/stemforge/
# MODEL_LOCATION=/data/models

# Server ports
# STEMFORGE_PORT=8765
# ACESTEP_PORT=8001

# AceStep GPU selection (CUDA_VISIBLE_DEVICES for the AceStep subprocess)
# ACESTEP_GPU=0
